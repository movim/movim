#: [about]thanks
msgid "Thanks"
msgstr "Danke"

#: [about]developers
msgid "Developers"
msgstr "Entwickler"

#: [about]translators
msgid "Translators"
msgstr "Übersetzer"

#: [about]translators_text
msgid "Thanks to all the translators"
msgstr "Danke an alle Übersetzer"

#: [about]software
msgid "Software"
msgstr "Programm"

#: [about]resources
msgid "Resources"
msgstr "Ressourcen"

#: [about]api
msgid "API"
msgstr "API"

#: [about]info
msgid "Movim is an XMPP-based communication platform. All the project, except the following software and resources, is under"
msgstr "Movim ist eine XMPP-basierte Kommunikationsplattform. Das gesamte Projekt, ausgenommen der folgenden Anwendung und Ressourcen, sind unter"

#: [about]sourcecode_title
msgid "Sourcecode"
msgstr "Quellcode"

#: [about]sourcecode_text
msgid "Check out the sourcecode on the Github repository"
msgstr ""

#: [account]title [page]account
msgid "Account"
msgstr "Konto"

#: [account]account_management
msgid "Account management"
msgstr "Kontoverwaltung"

#: [account]password_change_title
msgid "Change my password"
msgstr "Mein Passwort ändern"

#: [account]password [credentials]password [form]password [input]password
msgid "Password"
msgstr "Passwort"

#: [account]password_confirmation
msgid "Password confirmation"
msgstr "Passwortbestätigung"

#: [account]password_changed
msgid "The password has been updated"
msgstr "Das Passwort wurde aktualisiert"

#: [account]password_not_same
msgid "The provided passwords are not the same"
msgstr "Die eingegebenen Passwörter stimmen nicht überein"

#: [account]delete
msgid "Delete your account"
msgstr "Ihr Konto löschen"

#: [account]delete_text
msgid "You will delete your XMPP account and all the relative information linked to it (profile, contacts, and publications)."
msgstr "Du wirst dein XMPP-Konto und alle verbundenen Informationen (Profil, Kontakte, Veröffentlichungen) löschen."

#: [account]delete_text_confirm
msgid "Type your full username"
msgstr "Gib deinen vollen Benutzernamen ein"

#: [account]delete_text_error
msgid "Please provide a valid username."
msgstr "Bitte gib einen richtigen Benutzernamen ein"

#: [account]gateway_title
msgid "Gateways"
msgstr "Gateways"

#: [account]clear
msgid "Leave this instance"
msgstr "Diesen Pod verlassen"

#: [account]clear_text
msgid "You will delete all the relative information linked to your account on this Movim instance (profile, contacts, and publications)."
msgstr "Du wirst alle Informationen löschen, die mit deinem Konto auf dieser Movim-Instanz verbunden sind (Profil, Kontakte und Veröffentlichungen)."

#: [account]clear_text_confirm
msgid "This action will not delete your account but will disconnect you from Movim."
msgstr "Diese Aktion wird dein Konto nicht löschen, sondern dich von Movim abmelden."

#: [account]delete_bundle_title
msgid "OMEMO Key deletion"
msgstr "OMEMO-Schlüssellöschung"

#: [account]delete_bundle_text
msgid "You are going to destroy the following OMEMO key. Your contacts will not be able to encrypt messages using that key anymore. This action cannot be reverted. Are you sure?"
msgstr "Du bist dabei, den folgenden OMEMO-Schlüssel zu zerstören. Deine Kontakte werden Nachrichten nicht mehr mit diesem Schlüssel verschlüsseln können. Diese Aktion kann nicht rückgängig gemacht werden. Bist du sicher?"

#: [adhoc]title
msgid "Actions"
msgstr "Aktionen"

#: [adhoc]completed
msgid "Action completed"
msgstr "Vorgang abgeschlossen"

#: [tools]title
msgid "Developer Tools"
msgstr "Entwicklerwerkzeuge"

#: [tools]sdp_to_jingle
msgid "Convert SDP to Jingle"
msgstr "SDP zu Jingle konvertieren"

#: [tools]sdp_title
msgid "SDP"
msgstr "SDP"

#: [tools]jingle_to_sdp
msgid "Convert Jingle to SDP"
msgstr "Jingle zu SDP konvertieren"

#: [tools]jingle_title
msgid "Jingle stanza"
msgstr "Jingle-Stanza"

#: [admin]general
msgid "General Settings"
msgstr "Grundeinstellungen"

#: [general]theme
msgid "Theme"
msgstr "Thema"

#: [general]language
msgid "Default language"
msgstr "Standardsprache"

#: [general]log_verbosity
msgid "Log verbosity"
msgstr "Protokollstufe"

#: [general]join_title
msgid "Your instance is public?"
msgstr "Deine Instanz ist öffentlich?"

#: [general]join_text
msgid "Register your instance on join.movim.eu and join the Movim federation!"
msgstr "Registriere deine Instanz auf join.movim.eu und tritt der Movim-Föderation bei!"

#: [restrictsuggestions]title
msgid "Restrict suggestions"
msgstr "Vorschläge einschränken"

#: [restrictsuggestions]text
msgid "Only suggest chatrooms, Communities, and other contents that are available on the user's XMPP server and related services"
msgstr "Nur Chaträume, Gemeinschaften und andere Inhalte vorschlagen, die auf dem XMPP-Server und den verbundenen Diensten des Benutzers verfügbar sind"

#: [chatonly]title
msgid "Chat only"
msgstr "Nur Nachrichten"

#: [chatonly]text
msgid "Disable all the social feature (Communities, Blog…) and keep only the chat ones"
msgstr "Alle Social-Funktionen (Gemeinschaften, Blog,…) deaktivieren und nur die Nachrichten-Funktion behalten."

#: [credentials]title
msgid "Administration Credential"
msgstr "Systemverwaltungsberechtigung"

#: [credentials]username [input]username
msgid "Username"
msgstr "Benutzername"

#: [credentials]re_password
msgid "Retype password"
msgstr "Passwort erneut eingeben"

#: [disableregistration]title
msgid "Disable the XMPP registration feature"
msgstr "XMPP-Registrierung deaktivieren"

#: [disableregistration]text
msgid "Remove the XMPP registration flow and buttons from the interface"
msgstr "Entfernt den XMPP-Registrierprozess und die dazugehörigen Buttons vom Interface"

#: [whitelist]title
msgid "Allowed XMPP Servers"
msgstr "Erlaubte XMPP-Server"

#: [whitelist]info1
msgid "If you want to specify a list of authorized XMPP servers on your Movim pod and forbid the connection on all the others please put their domain name(s) here, with comma (ex: movim.eu,jabber.fr)"
msgstr "Wenn du eine Liste von autorisierten XMPP-Servern auf deinem Movim-Pod spezifizieren und die Verbindung von allen anderen Servern verbieten möchtest, füge die Domain-Namen hier ein und trenne sie mit einem Komma (z.B. movim.eu,jabber.fr)"

#: [whitelist]info2
msgid "Leave this field blank if you allow the access to all the XMPP accounts."
msgstr "Dieses Feld leer lassen, um den Zugriff auf alle XMPP-Konten zu erlauben."

#: [whitelist]label
msgid "List of allowed XMPP servers"
msgstr "Liste der erlaubten XMPP-Server"

#: [information]title
msgctxt "[information]title"
msgid "Information Message"
msgstr "Informationsnachricht"

#: [information]description [communityconfig]description
msgid "Description"
msgstr "Beschreibung"

#: [information]description_placeholder
msgid "General description of the instance"
msgstr "Generelle Beschreibung der Instanz."

#: [information]banner
msgid "Main banner"
msgstr "Hauptbanner"

#: [information]banner_info
msgid "Ensure that the picture is not too large and can be reached from any webpages"
msgstr "Stelle sicher, dass das Bild nicht zu groß und von allen Webseiten erreichbar ist"

#: [information]info1
msgid "This message will be displayed on the login page. It can be used to link the Terms and Conditions of your Movim instance for example."
msgstr "Dieser Text wird auf der Anmeldeseite angezeigt. Er kann genutzt werden, um rechtliche Bestimmungen und Nutzungshinweise Ihrer Movim-Instanz zu verlinken."

#: [information]info2
msgid "Leave this field blank if you don’t want to show any message."
msgstr "Lassen Sie dieses Feld leer wenn Sie keine Nachricht anzeigen wollen."

#: [information]label
msgctxt "[information]label"
msgid "Information Message"
msgstr "Informationsnachricht"

#: [xmpp]title
msgid "Default XMPP server"
msgstr "Standard XMPP Server"

#: [xmpp]domain
msgid "Main XMPP server domain"
msgstr "Haupt-XMPP-Server-Domain"

#: [xmpp]description
msgid "Main XMPP server description"
msgstr "Beschreibung des Haupt-XMPP-Servers"

#: [xmpp]country
msgid "Main XMPP server country"
msgstr "Land des Haupt-XMPP-Servers"

#: [xmpp]country_pick
msgid "Pick a country in the list"
msgstr "Wähle ein Land aus der Liste"

#: [tenor]title
msgid "Tenor integration"
msgstr "Tenor-Integration"

#: [tenor]label
msgid "Your Tenor API Key"
msgstr "Dein Tenor API-Key"

#: [tenor]info1
msgid "Movim integrates the Tenor API to allow GIF search and publication in Chat"
msgstr "Movim integriert die Tenor-API, um GIFs zu suchen und im Chat zu senden"

#: [tenor]info2
msgid "Access Tenor and get your API key"
msgstr "Greife auf Tenor zu und erhalte deinen API-Key"

#: [log]empty
msgid "Empty"
msgstr "Leer"

#: [log]syslog
msgid "Syslog"
msgstr "Systemprotokoll"

#: [log]syslog_files
msgid "Syslog and files"
msgstr "Systemprotokoll und Dateien"

#: [maxsessions]title
msgid "Maximum of connected sessions"
msgstr "Maximum an verbundenen Sitzungen"

#: [maxsessions]info
msgid "Movim will forbid new users to connect when the limit is reached, set it to 0 to disable"
msgstr "Ist das Limit erreicht, können sich keine weiteren Benutzer verbinden. Setze es auf 0, um es zu deaktivieren."

#: [adminreported]reported_by
msgid "Reported by %s users"
msgstr "Von %s Benutzern gemeldet"

#: [adminreported]info
msgid "Those accounts were reported by some Movim users"
msgstr "Diese Konten wurden von einigen Movim-Benutzern gemeldet"

#: [adminreported]info2
msgid "You can choose to block them for all the other users"
msgstr "Du kannst dich entscheiden, sie für alle anderen Benutzer zu blockieren"

#: [adminsessions]title
msgid "Sessions"
msgstr "Sitzungen"

#: [adminsessions]text
msgid "Currently connected users on the pod"
msgstr "Zurzeit verbundene Nutzer auf dem Pod"

#: [avatar]file
msgid "File"
msgstr "Datei"

#: [avatar]updated
msgid "Profile Picture Updated"
msgstr "Profilbild aktualisiert"

#: [avatar]not_updated
msgid "Profile Picture Not Updated"
msgstr "Profilbild nicht aktualisiert"

#: [avatar]change
msgid "Change my profile picture"
msgstr "Ändere mein Profilbild"

#: [avatar]too_big
msgid "Your picture is too big"
msgstr "Das Bild ist zu groß"

#: [avatar]missing
msgid "No avatar yet"
msgstr "Noch kein Avatar"

#: [banner]change
msgid "Change my banner"
msgstr "Ändere mein Banner"

#: [banner]updated
msgid "Banner Updated"
msgstr "Banner aktualisiert"

#: [banner]not_updated
msgid "Banner Not Updated"
msgstr "Banner nicht aktualisiert"

#: [banner]missing
msgid "No banner yet"
msgstr "Noch kein Banner"

#: [blocked]title
msgid "Blocked"
msgstr "Blockiert"

#: [blocked]block_account
msgid "Block the account"
msgstr "Blockiere das Konto"

#: [blocked]unblock_account
msgid "Unblock the account"
msgstr "Konto freigeben"

#: [blocked]account_blocked
msgid "Account blocked"
msgstr "Konto blockiert"

#: [blocked]account_unblocked
msgid "Account unblocked"
msgstr "Konto freigegeben"

#: [blocked]placeholder
msgid "You will find here the users you have blocked"
msgstr "Hier wirst du die Benutzer finden, die du blockier hast"

#: [blocked]info
msgid "The following users are blocked by Movim and cannot contact you anymore"
msgstr "Die folgenden Benutzer wurden von Movim blockiert und können dich nicht weiter kontaktieren"

#: [blocked]info2
msgid "The administrator is also aware of this list and can therefore block those users system wide"
msgstr "Der Administrator kennt diese Liste ebenfalls und kann die Benutzer daher systemweit blockieren"

#: [blog]title
msgid "%s’s blog"
msgstr "%ss Blog"

#: [blog]private
msgid "This content is private, please login to see it"
msgstr "Dieser Inhalt ist privat, bitte melde dich an, um ihn zu sehen"

#: [message]published
msgid "Message Published"
msgstr "Nachricht veröffentlicht"

#: [message]react
msgid "Add a reaction"
msgstr "Reaktion hinzufügen"

#: [message]retract
msgid "Retract"
msgstr "Nachricht löschen"

#: [message]retract_body
msgid "Your contact attempted to retract a previous message, but it's unsupported by your client"
msgstr "Dein Kontakt hat versucht, eine vorherige Nachricht zurückzuziehen, aber dies wird durch deinen Client nicht unterstützt"

#: [message]moderate_body
msgid "This message was moderated"
msgstr "Diese Nachricht wurde moderiert"

#: [message]error
msgid "Your message could not be sent, please try again later"
msgstr "Die Nachricht konnte nicht gesendet werden. Bitte später noch einmal versuchen"

#: [message]encrypted [omemo]encrypted
msgid "Encrypted message"
msgstr "Verschlüsselte Nachricht"

#: [message]retracted
msgid "Retracted message"
msgstr "Zurückgezogene Nachricht"

#: [message]composing
msgid "Composing…"
msgstr "Schreibt…"

#: [message]invitation
msgid "Invitation"
msgstr "Einladung"

#: [message]paused
msgid "Paused…"
msgstr "Pausiert..."

#: [message]gone
msgid "Contact gone"
msgstr "Kontakt verschwunden"

#: [message]edit_help
msgid "↑ to edit your previous message"
msgstr "↑ um deine letzte Nachricht zu editieren "

